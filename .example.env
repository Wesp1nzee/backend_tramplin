PROJECT_NAME="Tramplin API"
ENVIRONMENT=dev
DEBUG=True  # Swagger отключается если False!
API_V1_STR=/api/v1

# Безопасность
SECRET_KEY=test_secret_key_2026_secure_minimum_32_bytes
ALGORITHM= # Любой HS256, HS384, HS512, RS256, RS384, RS512, ES25, ES384, ES512
ACCESS_TOKEN_EXPIRE_MINUTES=0
REFRESH_TOKEN_EXPIRE_MINUTES=0

# Admin credentials (required)
DEFAULT_ADMIN_EMAIL=admin@tramplin.ru
DEFAULT_ADMIN_PASSWORD=ChangeMeInProduction123!

# PostgreSQL
POSTGRES_SERVER=localhost
POSTGRES_USER=tramplin_admin
POSTGRES_PASSWORD=secure_pass_2026_top_secret
POSTGRES_DB=tramplin_db

# Redis
REDIS_URL=redis://localhost:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# CORS
CORS_ORIGINS=http://localhost:3000,https://tramplin.edu

# S3 Storage (MinIO for development)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=tramplin-uploads
S3_REGION=us-east-1

# Business Logic
MAX_IMAGE_SIZE_MB=5
MAX_MEDIA_SIZE_MB=10

# Dadata API
DADATA_SECRET_KEY=your_dadata_secret_key
DADATA_API_KEY=your_dadata_api_key
